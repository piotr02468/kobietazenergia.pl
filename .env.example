# Skopiuj ten plik do .env i uzupelnij wartosci
# cp .env.example .env

# Haslo do panelu admina (wymagane)
ADMIN_PASSWORD=

# Connection string z MongoDB Atlas:
# Skopiuj z Atlas -> Connect -> Drivers
# Przyklad: mongodb+srv://uzytkownik:haslo@cluster0.xxxxx.mongodb.net/opinieDB?retryWrites=true&w=majority
MONGO_URI=

# Port lokalny (na Render ustawiany automatycznie)
PORT=3000
